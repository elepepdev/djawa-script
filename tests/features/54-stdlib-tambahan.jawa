// Test: Himpunan (Set) & PetaLemah (WeakMap) & URL
cetakno("--- Stdlib Tambah ---");

iki iku him yoiku Himpunan();
him.nambah(1);
him.nambah(2);
him.nambah(2);
him.nambah(3);
