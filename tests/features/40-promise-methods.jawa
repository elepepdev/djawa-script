cetakno('--- Tes Janji Methods (.banjur, .nyekel) ---')

// Simulasi Janji yang berhasil
iki iku janjiSukses yoiku Janji anyar((resolve, reject) lakoni terus
  setWaktuTunda(() lakoni resolve('Data berhasil!'), 100)
mbari)

janjiSukses
  .banjur(pesan lakoni cetakno('Sukses:', pesan))
  .nyekel(error lakoni cetakno('Kesalahan (tidak seharusnya terjadi):', error))

// Simulasi Janji yang gagal
iki iku janjiGagal yoiku Janji anyar((resolve, reject) lakoni terus
  setWaktuTunda(() lakoni reject('Ada masalah!'), 50)
mbari)

janjiGagal
  .banjur(pesan lakoni cetakno('Sukses (tidak seharusnya terjadi):', pesan))
  .nyekel(error lakoni cetakno('Kesalahan:', error))

cetakno('Janji sedang diproses...')