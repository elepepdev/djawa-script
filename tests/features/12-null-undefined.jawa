// Test for null and undefined keywords

jarno nilaiKosong yoiku kosong
jarno nilaiOraDidefinisikan yoiku oraDidefinisikan

cetakno("Nilai Kosong: " + nilaiKosong)
cetakno("Nilai Ora Didefinisikan: " + nilaiOraDidefinisikan)

lek (nilaiKosong podoyoiku kosong) terus
  cetakno("nilaiKosong adalah kosong")
mbari

lek (nilaiOraDidefinisikan podoyoiku oraDidefinisikan) terus
  cetakno("nilaiOraDidefinisikan adalah oraDidefinisikan")
mbari
