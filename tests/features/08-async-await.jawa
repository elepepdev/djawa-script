// Test Async/Await

gawe tenangan ambilData() terus
  cetakno("Mulai ambil data...")
  jarno data yoiku enteni anyar Janji(resolve lakoni Wektu.ngenteni(() lakoni resolve("Data dari server"), 100))
  balekno data
mbari

