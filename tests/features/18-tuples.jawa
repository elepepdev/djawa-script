// Test Tuple literal assignment
jarno koordinat yoiku tuple(10, 20)
cetakno(koordinat[0]) // Should be 10
cetakno(koordinat[1]) // Should be 20

// Test immutability (this should ideally throw an error if Jawascript had runtime type checking,
// but in JS it will just fail silently or throw if in strict mode)
// We expect the transpiled JS to use Object.freeze, so direct modification should fail.
cobak terus
  koordinat[0] yoiku 5 // This line should not change the tuple
mbari nyekel e terus
  cetakno("Error nalika ngowahi tuple: " tambah e.message)
mbari
cetakno(koordinat[0]) // Should still be 10

// Test tuple in function argument
gawe tampilkanTitik(titik) terus
  cetakno("Titik X: " tambah titik[0])
  cetakno("Titik Y: " tambah titik[1])
mbari

tampilkanTitik(tuple(100, 200))

// Test tuple with different types
jarno info yoiku tuple("nama", 25, tenan)
cetakno(info[0]) // "nama"
cetakno(info[1]) // 25
cetakno(info[2]) // true

// Test tuple with expressions
jarno hitungan yoiku tuple(1 tambah 2, 3 ping 4)
cetakno(hitungan[0]) // 3
cetakno(hitungan[1]) // 12
