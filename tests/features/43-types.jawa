jarno umur yoiku 30
jarno jeneng yoiku "Budi"
jarno isAktif yoiku tenan

gawe sapa(jeneng) terus
  balekno "Halo " tambah jeneng
mbari

gawe tambah(a, b) terus
  balekno a tambah b
mbari

jarno getUmur yoiku (tahunLahir) lakoni
  balekno 2025 kurang tahunLahir

jarno cetakInfo yoiku (pesan, jumlah) lakoni terus
  cetakno(pesan tambah ": " tambah jumlah)
mbari

cetakno("Umur: " tambah umur)
cetakno("Nama: " tambah jeneng)
cetakno("Aktif: " tambah isAktif)
cetakno(sapa("Dina"))
cetakno(tambah(5, 7))
cetakno(getUmur(1990))
cetakInfo("Total", 100)
