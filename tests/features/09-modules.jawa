// Test Module Imports and Exports

// Export named
metokno terus fungsiA, variabelB mbari

// Export default
metokno biasane kelas MyClass terus
  // ...
mbari

// Import named
jupukno terus fungsiA, variabelB dadi aliasB mbari soko './module.js'

// Import default
jupukno biasane DefaultExport soko './anotherModule.js'

// Import everything as
jupukno * dadi AllFromModule soko './yetAnotherModule.js'
