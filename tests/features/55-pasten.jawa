// Test: Pasten inline assertion
cetakno("--- Pasten (Assertion) ---")

pasten(2 + 2 podo 4, "matematika tetep")
pasten("hello" + "world" podo "helloworld", "string concat")

gawe jodohaken(a, b) terus
  pastenPodo(a, b, "argumen kudu podo")
  balekno "cocok"
mbari

cetakno(jodohaken(1, 1))

gawe jodahHasil(n) terus
  pasten(n luwihGedhePodo 0, "n kudu non-negatif")
  balekno n * 2
mbari

cetakno(jodahHasil(5))

cetakno("--- Rampung ---")
