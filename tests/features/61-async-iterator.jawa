// Test: Async Iterator (kanggo tenangan ... soko ...)
cetakno("--- Async Iterator ---")

// Build an async iterable
jarno asyncRange yoiku terusmbari
jarno i yoiku 0
jarno nextFn yoiku () lakoni terus
  i yoiku i + 1
  lek i <yoiku 3 terus
    balekno terus value: i * 10, done: gak mbari
  mbari
  balekno terus done: tenan mbari
mbari
jarno iterObj yoiku terus next: nextFn mbari
asyncRange[Simbol.asyncIterator] yoiku () lakoni terus
  balekno iterObj
mbari

// Test async iteration
cetakno("Async range:")
kanggo tenangan jarno val soko asyncRange terus
  cetakno("nilai: ", val)
mbari

cetakno("--- after async for-of ---")

// Test with string values
jarno step yoiku 0
jarno nextFn2 yoiku () lakoni terus
  step yoiku step + 1
  lek step <yoiku 2 terus
    balekno terus value: "data-" + step, done: gak mbari
  mbari
  balekno terus done: tenan mbari
mbari
jarno stringIter yoiku terusmbari
jarno iterObj2 yoiku terus next: nextFn2 mbari
stringIter[Simbol.asyncIterator] yoiku () lakoni terus
  balekno iterObj2
mbari

kanggo tenangan iki iku item soko stringIter terus
  cetakno(item)
mbari

cetakno("--- Rampung ---")
