{
  "name": "@jawirhytam/djawascript",
  "version": "2.3.0",
  "description": "Jawascript is a programming language for someone who did'nt understand English very much.",
  "homepage": "https://github.com/elepepdev/djawa-script#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elepepdev/djawa-script.git"
  },
  "bugs": {
    "url": "https://github.com/elepepdev/djawa-script/issues"
  },
  "bin": {
    "djawa": "./cli.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build:bin": "node bin/build.js",
    "build:bin:linux-x64": "node bin/build.js --platform linux --arch x64",
    "build:bin:linux-arm64": "node bin/build.js --platform linux --arch arm64",
    "build:bin:macos-x64": "node bin/build.js --platform macos --arch x64",
    "build:bin:macos-arm64": "node bin/build.js --platform macos --arch arm64",
    "build:bin:windows-x64": "node bin/build.js --platform windows --arch x64"
  },
  "keywords": [
    "jawascript",
    "jawa",
    "jawir-script",
    "programming-language",
    "javanese",
    "language",
    "interpreter",
    "javascript",
    "js",
    "parser",
    "cli",
    "indonesia",
    "bahasa",
    "bahasa-pemrograman",
    "custom-language",
    "learning",
    "education",
    "oop",
    "async-await"
  ],
  "author": "Fatih Faisal Faruk (jawirhytam)",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "dependencies": {
    "prompt-sync": "^4.2.0"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  }
}