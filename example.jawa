// example.jawa
// Kodeku elek mas :p

jarno a yoiku 1
jarno b yoiku 2
iki iku interval yoiku 2
 
cetakno(a + b)

lek (a luwihGedhe b) terus
  cetakno("Ha ah lah")
mbari liyane terus
  cetakno("Nggak le")
mbari 

jarno arr1 yoiku [1, 2, 3, 4, 5 ]
jarno arr2 yoiku [6, 7, 8, 9, 10]

iki iku arr3 yoiku arr1.gabungno(arr2)
cetakno(arr3)

ngenteni interval
cetakno("done")

lek interval guduk 1 terus
  cetakno "intervalnya bukan 1"
mbari liyane terus
  cetakno "intervalnya 1"
mbari